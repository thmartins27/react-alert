{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    // "allowImportingTsExtensions": true, // Remova ou comente esta linha
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": false, // Certifique-se de que é false para gerar arquivos JavaScript
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    /* Output */
    "outDir": "./dist", // Saída dos arquivos compilados
    "declaration": true, // Gera arquivos .d.ts
    "declarationDir": "./dist/types" // Diretório para os arquivos .d.ts
  },
  "include": ["src"]
}